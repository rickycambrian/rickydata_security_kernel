{
  "name": "@rickydata/security-kernel",
  "version": "1.1.3",
  "description": "Security kernel for Rickydata - TPM sealing, encryption, and sign-to-derive key derivation",
  "main": "dist-cjs/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/rickycambrian/rickydata_security_kernel"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist-cjs/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc && tsc -p tsconfig.cjs.json",
    "build:esm": "tsc",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "security",
    "tpm",
    "encryption",
    "hkdf",
    "sign-to-derive"
  ],
  "author": "Ricky Cambrian",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
